# Root environment for docker-compose variable interpolation
# Currently used key in docker-compose.yaml:
# - NGROK_AUTHTOKEN (optional, required only when ngrok container is used)

NGROK_AUTHTOKEN=

# Runtime settings for services are configured in:
# - services/auth/.env.docker
# - services/bot/.env.docker
# - services/candidate/.env.docker
# - services/employer/.env.docker
# - services/file/.env.docker
# - services/search/.env.docker
#
# Sensitive overrides should be stored in gitignored files:
# - services/*/.env.local
# Templates:
# - services/*/.env.example
# - services/*/.env.local.example
