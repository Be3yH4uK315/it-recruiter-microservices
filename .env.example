# ==============================================================================
# GLOBAL SETTINGS
# ==============================================================================
ENVIRONMENT=local
LOG_LEVEL=INFO

# Security (ОБЯЗАТЕЛЬНО СГЕНЕРИРОВАТЬ НОВЫЕ ДЛЯ ПРОДАКШЕНА)
# Можно сгенерировать командой: openssl rand -hex 32
SECRET_KEY=replace_this_with_a_very_secret_key
INTERNAL_BOT_SECRET=replace_this_with_a_bot_secret

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Messaging & Circuit Breakers
CANDIDATE_EXCHANGE_NAME=candidate_events
DLQ_EXCHANGE_NAME=candidate_events_dlq
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30
RATE_LIMIT_DEFAULT=100/minute

# Storage (S3/MinIO)
S3_REGION=us-east-1
MAX_FILE_SIZE=10485760
# Впиши сюда свой публичный домен (ngrok или реальный) для раздачи файлов
S3_PUBLIC_DOMAIN=https://your-public-domain.ngrok-free.dev/s3

# Search & ML Parameters
CANDIDATE_INDEX_ALIAS=candidates
MILVUS_COLLECTION_NAME=candidates_embeddings
SENTENCE_MODEL_NAME=paraphrase-multilingual-mpnet-base-v2
RANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
RETRIEVAL_SIZE=100
RERANK_TOP_K=50
RRF_K=60
FACTOR_NO_SKILLS=0.5
FACTOR_EXP_MISMATCH=0.8
FACTOR_LOCATION_MATCH=1.1

# ==============================================================================
# TELEGRAM BOT
# ==============================================================================
# Токен бота от @BotFather
BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTuvwXyz_12345678
# Telegram ID администраторов (через запятую)
ADMIN_IDS=123456789, 987654321

# ==============================================================================
# PORTS (External access)
# ==============================================================================
PORT_GATEWAY=80
PORT_AUTH=8003
PORT_CANDIDATE=8000
PORT_SEARCH=8001
PORT_EMPLOYER=8002
PORT_FILE=8004
PORT_REDIS=6379
PORT_RABBITMQ=5672
PORT_RABBITMQ_UI=15672
PORT_MINIO=9000
PORT_MINIO_CONSOLE=9001
PORT_PROMETHEUS=9090
PORT_GRAFANA=3000
PORT_JAEGER_UI=16686

# ==============================================================================
# SHARED INFRASTRUCTURE CREDENTIALS
# ==============================================================================
REDIS_HOST=shared_redis
REDIS_PORT=6379

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET_NAME=recruiter-files

# ==============================================================================
# DATABASES (POSTGRES)
# ==============================================================================
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_secret_password
AUTH_DB_NAME=auth_db
AUTH_DATABASE_URL=postgresql+asyncpg://auth_user:auth_secret_password@auth-db:5432/auth_db

CANDIDATE_DB_USER=candidate_user
CANDIDATE_DB_PASSWORD=candidate_secret_password
CANDIDATE_DB_NAME=candidate_db
CANDIDATE_DATABASE_URL=postgresql+asyncpg://candidate_user:candidate_secret_password@candidate-db:5432/candidate_db

EMPLOYER_DB_USER=employer_user
EMPLOYER_DB_PASSWORD=employer_secret_password
EMPLOYER_DB_NAME=employer_db
EMPLOYER_DATABASE_URL=postgresql+asyncpg://employer_user:employer_secret_password@employer-db:5432/employer_db

FILE_DB_USER=file_user
FILE_DB_PASSWORD=file_secret_password
FILE_DB_NAME=file_db
FILE_DATABASE_URL=postgresql+asyncpg://file_user:file_secret_password@file-db:5432/file_db

# ==============================================================================
# SERVICE URLS (Internal Docker Network)
# ==============================================================================
AUTH_SERVICE_URL=http://auth-service:8000
CANDIDATE_SERVICE_URL=http://candidate-api:8000
EMPLOYER_SERVICE_URL=http://employer-service:8000
SEARCH_SERVICE_URL=http://search-service:8000
FILE_SERVICE_URL=http://file-service:8000
GATEWAY_URL=http://gateway:80

ELASTICSEARCH_URL=http://elasticsearch:9200
MILVUS_HOST=milvus
MILVUS_PORT=19530
