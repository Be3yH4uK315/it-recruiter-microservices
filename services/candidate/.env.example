APP_NAME=candidate-service
APP_VERSION=0.1.0
APP_ENV=docker
DEBUG=false

HOST=0.0.0.0
PORT=8000

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/candidates
SQL_ECHO=false
DB_POOL_SIZE=40
DB_MAX_OVERFLOW=80
DB_POOL_PRE_PING=true

HTTP_CLIENT_CONNECT_TIMEOUT_SECONDS=5.0
HTTP_CLIENT_READ_TIMEOUT_SECONDS=5.0
HTTP_CLIENT_WRITE_TIMEOUT_SECONDS=5.0
HTTP_CLIENT_POOL_TIMEOUT_SECONDS=5.0
HTTP_CLIENT_MAX_CONNECTIONS=200
HTTP_CLIENT_MAX_KEEPALIVE_CONNECTIONS=50
HTTP_CLIENT_KEEPALIVE_EXPIRY_SECONDS=20.0

EMPLOYER_SERVICE_URL=http://employer-api:8000
FILE_SERVICE_URL=http://file-api:8000
AUTH_SERVICE_URL=http://auth-api:8000

INTERNAL_SERVICE_TOKEN=change-me-internal-service-token

RABBITMQ_URL=amqp://app:app@rabbitmq:5672/
RABBITMQ_EXCHANGE=candidate.events
OUTBOX_BATCH_SIZE=100
OUTBOX_POLL_INTERVAL_SECONDS=1.0
OUTBOX_MAX_RETRIES=10

EMPLOYER_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
EMPLOYER_CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=30
FILE_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
FILE_CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=30

LOG_LEVEL=INFO
LOG_JSON=true

REQUEST_ID_HEADER_NAME=X-Request-ID
EXPOSE_REQUEST_ID_HEADER=true

IDEMPOTENCY_ENABLED=true
IDEMPOTENCY_HEADER_NAME=Idempotency-Key

SWAGGER_ENABLED=true
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json