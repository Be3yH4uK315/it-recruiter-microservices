APP_NAME=telegram-bot-service
APP_VERSION=0.1.0
APP_ENV=docker
DEBUG=false

HOST=0.0.0.0
PORT=8000

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/telegram_bot
SQL_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_PRE_PING=true

HTTP_CLIENT_CONNECT_TIMEOUT_SECONDS=5.0
HTTP_CLIENT_READ_TIMEOUT_SECONDS=10.0
HTTP_CLIENT_WRITE_TIMEOUT_SECONDS=10.0
HTTP_CLIENT_POOL_TIMEOUT_SECONDS=5.0
HTTP_CLIENT_MAX_CONNECTIONS=200
HTTP_CLIENT_MAX_KEEPALIVE_CONNECTIONS=50
HTTP_CLIENT_KEEPALIVE_EXPIRY_SECONDS=20.0

AUTH_SERVICE_URL=http://auth-api:8000
CANDIDATE_SERVICE_URL=http://candidate-api:8000
EMPLOYER_SERVICE_URL=http://employer-api:8000
SEARCH_SERVICE_URL=http://search-api:8000

INTERNAL_SERVICE_TOKEN=change-me-internal-service-token

TELEGRAM_BOT_TOKEN=change-me-telegram-bot-token
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_MODE=webhook
TELEGRAM_WEBHOOK_PATH=/api/v1/telegram/webhook
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET_TOKEN=change-me-webhook-secret

NGROK_API_URL=http://ngrok:4040
TELEGRAM_WEBHOOK_DISCOVERY_TIMEOUT_SECONDS=90
TELEGRAM_WEBHOOK_DISCOVERY_POLL_INTERVAL_SECONDS=2.0

BOT_CALLBACK_PREFIX=ctx:
CALLBACK_CONTEXT_TTL_SECONDS=900
AUTH_ACCESS_TOKEN_REFRESH_SKEW_SECONDS=60

REQUEST_ID_HEADER_NAME=X-Request-ID
EXPOSE_REQUEST_ID_HEADER=true

SWAGGER_ENABLED=true
METRICS_ENABLED=true
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json

CORS_ALLOW_ORIGINS=[]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

LOG_LEVEL=INFO
LOG_JSON=true