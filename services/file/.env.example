APP_NAME=file-service
APP_VERSION=0.1.0
APP_ENV=docker
DEBUG=false

HOST=0.0.0.0
PORT=8000
APP_PORT=8000

POSTGRES_DB=files
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/files
SQL_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_PRE_PING=true

S3_ENDPOINT_URL=http://file-minio:9000
S3_PUBLIC_ENDPOINT_URL=
NGROK_API_URL=http://ngrok:4040
NGROK_TUNNEL_ADDR_CONTAINS=nginx:80
S3_PUBLIC_ENDPOINT_DISCOVERY_TIMEOUT_SECONDS=90
S3_PUBLIC_ENDPOINT_DISCOVERY_POLL_INTERVAL_SECONDS=2.0
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET_NAME=files
S3_FORCE_PATH_STYLE=true
DEFAULT_UPLOAD_URL_EXPIRATION_SECONDS=3600
DEFAULT_DOWNLOAD_URL_EXPIRATION_SECONDS=3600

RABBITMQ_URL=amqp://app:app@rabbitmq:5672/
RABBITMQ_EXCHANGE=file.events
RABBITMQ_CLEANUP_QUEUE=file.cleanup.requested.queue
RABBITMQ_CLEANUP_ROUTING_KEY=file.cleanup.requested
OUTBOX_BATCH_SIZE=100
OUTBOX_POLL_INTERVAL_SECONDS=1.0
OUTBOX_MAX_RETRIES=10

INTERNAL_SERVICE_TOKEN=change-me-internal-service-token

LOG_LEVEL=INFO
LOG_JSON=true

REQUEST_ID_HEADER_NAME=X-Request-ID
EXPOSE_REQUEST_ID_HEADER=true

IDEMPOTENCY_ENABLED=true
IDEMPOTENCY_HEADER_NAME=Idempotency-Key

SWAGGER_ENABLED=true
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json

CORS_ALLOW_ORIGINS=[]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

MAX_FILENAME_LENGTH=255
MAX_CONTENT_TYPE_LENGTH=255
MAX_OBJECT_KEY_LENGTH=1024

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
