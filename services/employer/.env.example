APP_NAME=employer-service
APP_VERSION=0.1.0
APP_ENV=docker
DEBUG=false

HOST=0.0.0.0
PORT=8000

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/employers
SQL_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_PRE_PING=true

HTTP_CLIENT_CONNECT_TIMEOUT_SECONDS=5
HTTP_CLIENT_READ_TIMEOUT_SECONDS=5
HTTP_CLIENT_WRITE_TIMEOUT_SECONDS=5
HTTP_CLIENT_POOL_TIMEOUT_SECONDS=5
HTTP_CLIENT_MAX_CONNECTIONS=200
HTTP_CLIENT_MAX_KEEPALIVE_CONNECTIONS=50
HTTP_CLIENT_KEEPALIVE_EXPIRY_SECONDS=20

CANDIDATE_SERVICE_URL=http://candidate-api:8000
SEARCH_SERVICE_URL=http://search-api:8000
AUTH_SERVICE_URL=http://auth-api:8000

INTERNAL_SERVICE_TOKEN=change-me-internal-service-token

SEARCH_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
SEARCH_CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=30
CANDIDATE_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CANDIDATE_CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=30

RABBITMQ_URL=amqp://app:app@rabbitmq:5672/
RABBITMQ_EXCHANGE=employer.events
OUTBOX_BATCH_SIZE=100
OUTBOX_POLL_INTERVAL_SECONDS=1
OUTBOX_MAX_RETRIES=10

LOG_LEVEL=INFO
LOG_JSON=false

REQUEST_ID_HEADER_NAME=X-Request-ID
EXPOSE_REQUEST_ID_HEADER=true

IDEMPOTENCY_ENABLED=true
IDEMPOTENCY_HEADER_NAME=Idempotency-Key

SWAGGER_ENABLED=true
METRICS_ENABLED=true
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json