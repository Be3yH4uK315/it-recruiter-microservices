APP_NAME=auth-service
APP_VERSION=0.1.0
APP_ENV=docker
DEBUG=false

HOST=0.0.0.0
PORT=8000

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/auth
SQL_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_PRE_PING=true

JWT_SECRET_KEY=change-me-jwt-secret-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
MAX_ACTIVE_REFRESH_SESSIONS=5

TELEGRAM_BOT_TOKEN=change-me-telegram-bot-token
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400

INTERNAL_BOT_SECRET=change-me-internal-bot-secret
INTERNAL_SERVICE_TOKEN=change-me-internal-service-token

RABBITMQ_URL=amqp://app:app@rabbitmq:5672/
RABBITMQ_EXCHANGE=auth.events
OUTBOX_BATCH_SIZE=100
OUTBOX_POLL_INTERVAL_SECONDS=1.0
OUTBOX_MAX_RETRIES=10

LOG_LEVEL=INFO
LOG_JSON=true

REQUEST_ID_HEADER_NAME=X-Request-ID
EXPOSE_REQUEST_ID_HEADER=true

IDEMPOTENCY_ENABLED=true
IDEMPOTENCY_HEADER_NAME=Idempotency-Key

SWAGGER_ENABLED=true
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json