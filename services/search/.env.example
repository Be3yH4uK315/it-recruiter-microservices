APP_NAME=search-service
APP_VERSION=0.1.0
APP_ENV=docker
DEBUG=false

HOST=0.0.0.0
PORT=8000

SEARCH_SERVICE_URL=http://search-api:8000
CANDIDATE_SERVICE_URL=http://candidate-api:8000
INTERNAL_SERVICE_TOKEN=change-me-internal-service-token

ELASTICSEARCH_URL=http://search-elasticsearch:9200
CANDIDATE_INDEX_ALIAS=candidates

MILVUS_HOST=search-milvus
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=candidate_embeddings
MILVUS_EMBEDDING_DIM=384

SENTENCE_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RANKER_MODEL_NAME=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
ML_CONCURRENCY_LIMIT=1

RETRIEVAL_SIZE=100
RERANK_TOP_K=30
RRF_K=60

FACTOR_NO_SKILLS=0.85
FACTOR_EXP_MISMATCH=0.90
FACTOR_LOCATION_MATCH=1.10

RABBITMQ_URL=amqp://app:app@rabbitmq:5672/
CANDIDATE_EXCHANGE_NAME=candidate.events
CANDIDATE_QUEUE_NAME=search_service_queue
RABBITMQ_PREFETCH_COUNT=1
RABBITMQ_RECONNECT_DELAY_SECONDS=5.0

LOG_LEVEL=INFO
LOG_JSON=true

REQUEST_ID_HEADER_NAME=X-Request-ID
EXPOSE_REQUEST_ID_HEADER=true

SWAGGER_ENABLED=true
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json
